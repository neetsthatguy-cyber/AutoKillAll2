local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")


local MAX_HEALTH = 1000
local MAX_SPEED  = 1000
local TELEPORT_RANGE = 500 


humanoid.MaxHealth = MAX_HEALTH
humanoid.Health    = MAX_HEALTH
humanoid.WalkSpeed = MAX_SPEED


local bodyGyro = Instance.new("BodyGyro")
bodyGyro.MaxTorque = Vector3.new(1e6, 1e6, 1e6)  
bodyGyro.D         = 100                    
bodyGyro.P         = 3000                  
bodyGyro.CFrame    = rootPart.CFrame          
bodyGyro.Parent    = rootPart


humanoid.HealthChanged:Connect(function(health)
    if health < MAX_HEALTH then
        humanoid.Health = MAX_HEALTH
    end
end)


local lastTeleport = 0

RunService.Heartbeat:Connect(function()
    local now = tick()


    humanoid.MaxHealth = MAX_HEALTH
    humanoid.Health    = MAX_HEALTH
    humanoid.WalkSpeed = MAX_SPEED


    if now - lastTeleport >= 1 then
        lastTeleport = now

        local randomX = math.random(-TELEPORT_RANGE, TELEPORT_RANGE)
        local randomZ = math.random(-TELEPORT_RANGE, TELEPORT_RANGE)
        local randomY = math.random(5, 50)  -- keep slightly above ground

        rootPart.CFrame = CFrame.new(randomX, randomY, randomZ)

        bodyGyro.CFrame = CFrame.new(randomX, randomY, randomZ)
    end
end)
